# AIKosh Quality Toolkit Environment Configuration Example
# Copy this file to .env and adjust variables as necessary

# App Settings
PROJECT_NAME="AIKosh Dataset Quality Evaluation Toolkit"
API_V1_STR="/api/v1"

# Postgres Database Settings
# Note: For Supabase/remote Postgres, set POSTGRES_HOST to your project db host (e.g. db.skincirarsrwnzpdxhlf.supabase.co) and POSTGRES_DB to postgres.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis Settings
# Note: For docker-compose use: redis://redis:6379/0
# For local run use: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# MinIO / AWS S3 Object Storage Settings
# Note: For docker-compose use: http://minio:9000
# For local run use: http://localhost:9000
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=changeme
S3_SECRET_KEY=changeme
S3_BUCKET_NAME=aikosh-datasets
S3_REGION=us-east-1

# Security
API_KEY_SECRET=changeme
JWT_SECRET=changeme
REDIS_PASSWORD=changeme

# Frontend Configuration (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000

