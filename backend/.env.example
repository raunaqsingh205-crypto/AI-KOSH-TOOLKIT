# AIKosh Backend Settings Configuration Example
# Copy this to .env inside the backend folder for local runs

PROJECT_NAME="AIKosh Dataset Quality Evaluation Toolkit"
API_V1_STR="/api/v1"

# Postgres Database Settings
# Note: For Supabase/remote Postgres, set POSTGRES_HOST to your project db host (e.g. db.skincirarsrwnzpdxhlf.supabase.co) and POSTGRES_DB to postgres.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis Settings
# For running locally (outside Docker), use localhost
REDIS_URL=redis://localhost:6379/0

# MinIO / AWS S3 Object Storage Settings
# For running locally (outside Docker), use localhost
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=aikosh-datasets
S3_REGION=us-east-1

# Security
API_KEY_SECRET=tkt_secret_super_secure_key_12345678
